#!/bin/bash

echo "========== BW6 Bulk Heap Update (Extended Properties) =========="

# ---------------------------------------------------------
# Load user environment (Fix for bwadmin.tra error)
# ---------------------------------------------------------
if [ -f ~/.bash_profile ]; then
    source ~/.bash_profile
elif [ -f ~/.profile ]; then
    source ~/.profile
fi

# ---------------------------------------------------------
# Validate BW_HOME
# ---------------------------------------------------------
if [ -z "$BW_HOME" ]; then
    echo "ERROR: BW_HOME not set. Please check environment."
    exit 1
fi

# Add bwadmin to PATH
export PATH=$BW_HOME/bin:$PATH

# Validate bwadmin command
if ! command -v bwadmin >/dev/null 2>&1; then
    echo "ERROR: bwadmin command not found in PATH."
    exit 1
fi

# ---------------------------------------------------------
# Input file
# ---------------------------------------------------------
read -p "Enter full path of input .txt file: " INPUT_FILE

if [ ! -f "$INPUT_FILE" ]; then
    echo "ERROR: Input file not found!"
    exit 1
fi

SUCCESS_COUNT=0
FAIL_COUNT=0

# ---------------------------------------------------------
# Process each line
# ---------------------------------------------------------
while IFS=',' read -r DOMAIN APPSPACE TRA_FILE HEAP_MAX HEAP_MIN || [ -n "$DOMAIN" ]
do
    # Skip empty lines
    [ -z "$DOMAIN" ] && continue

    echo "----------------------------------------------------------"
    echo "Processing: $DOMAIN | $APPSPACE"
    echo "----------------------------------------------------------"

    if [ ! -f "$TRA_FILE" ]; then
        echo "ERROR: TRA file not found"
        ((FAIL_COUNT++))
        continue
    fi

    # Backup
    cp "$TRA_FILE" "${TRA_FILE}.bak_$(date +%Y%m%d_%H%M%S)"

    echo "Updating heap in java.extended.properties..."

    # Update -Xmx
    sed -i "s/-Xmx[0-9]*[mMgG]*/-Xmx$HEAP_MAX/" "$TRA_FILE"

    # Update -Xms
    sed -i "s/-Xms[0-9]*[mMgG]*/-Xms$HEAP_MIN/" "$TRA_FILE"

    echo "Heap updated successfully."

    # Stop AppNode
    echo "Stopping AppNode..."
    bwadmin stop appnode -d "$DOMAIN" -a "$APPSPACE"
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to stop AppNode"
        ((FAIL_COUNT++))
        continue
    fi

    sleep 5

    # Start AppNode
    echo "Starting AppNode..."
    bwadmin start appnode -d "$DOMAIN" -a "$APPSPACE"
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to start AppNode"
        ((FAIL_COUNT++))
        continue
    fi

    sleep 15

    # Log Validation
    LOG_DIR=$(dirname "$TRA_FILE")/logs
    LATEST_LOG=$(ls -t "$LOG_DIR"/*.log 2>/dev/null | head -1)

    if [ -f "$LATEST_LOG" ]; then
        grep -i "Started" "$LATEST_LOG" >/dev/null
        if [ $? -eq 0 ]; then
            echo "Restart confirmed for $APPSPACE"
            ((SUCCESS_COUNT++))
        else
            echo "WARNING: Restart not confirmed in logs"
            ((FAIL_COUNT++))
        fi
    else
        echo "WARNING: Log file not found"
        ((FAIL_COUNT++))
    fi

done < "$INPUT_FILE"

echo "=========================================================="
echo "Bulk Operation Completed"
echo "Successful Updates : $SUCCESS_COUNT"
echo "Failed Updates     : $FAIL_COUNT"
echo "=========================================================="